# ==========================================
# NORTHWIND WEB APP – ENVIRONMENT VARIABLES
# ==========================================
# Sao chép file này thành .env và điền thông tin thực

# Tài khoản đăng nhập quản trị viên
ADMIN_USERNAME=admin

# Mật khẩu đã mã hoá bằng bcrypt (cost=12)
# Mật khẩu mặc định ban đầu: Admin@2024
# Thay đổi bằng cách chạy: node scripts/hash-password.js <mật_khẩu_mới>
ADMIN_PASSWORD_HASH=$2b$12$K7B5K9Oy5Dq1ZJEAZnvMguQ3VkZp2xB1pV.fqW4JRL0FW7Wkz6v2

# Khoá bí mật session (đổi thành chuỗi ngẫu nhiên dài ít nhất 32 ký tự)
SESSION_SECRET=9e1e418203a4b8dec9d63aba73aef414affdcc2bf6cff8e4c18f25a5bda2a9fb

# Cấu hình server
PORT=3000

# Đường dẫn tới database (tương đối từ thư mục app/)
DB_PATH=../dist/northwind.db

# Database engine: sqlite or mysql
DB_CLIENT=sqlite

# MySQL Workbench / MySQL Server
# Use these values when DB_CLIENT=mysql
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=northwind
MYSQL_CONNECTION_LIMIT=10
